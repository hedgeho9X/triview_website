---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import CallToAction from "../../../components/CallToAction.astro";
import CardMedia from "../../../components/CardMedia.astro";
import PageHero from "../../../components/PageHero.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import VisualPlaceholder from "../../../components/VisualPlaceholder.astro";
import MainLayout from "../../../layouts/MainLayout.astro";
import { siteConfig } from "../../../data/site";
import { getLocaleFromUrl, withLocale } from "../../../i18n/routing";

const locale = getLocaleFromUrl(Astro.url.pathname);

const posts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const latest = posts.slice(0, 6);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: `${siteConfig.name} 資源`,
    url: `${siteConfig.siteUrl}/zh-Hant/resources`,
    description: "宇睿電子的指南、清單與整合筆記，面向 LCD 控制板與工業顯示子系統專案。"
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: latest.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: post.data.title,
      url: `${siteConfig.siteUrl}/zh-Hant/resources/${post.slug}`
    }))
  }
];

const quickLinks = [
  {
    title: "快速確認介面覆蓋",
    description:
      "當關鍵問題是可行性：面板側介面（LVDS/eDP/V-by-One）、主機側輸入（HDMI/DP/DVI/VGA/USB-C）以及控制/OSD 範圍。",
    href: withLocale(locale, "/interface-summary"),
    label: "打開介面總覽"
  },
  {
    title: "瀏覽產品類別",
    description: "當你已明確硬體族群：控制板、scaler、觸控或線束配套。",
    href: withLocale(locale, "/products"),
    label: "查看產品"
  },
  {
    title: "選擇方案路徑",
    description: "當關鍵問題是客製整合、生命周期遷移或穩定的 HMI 子系統交付。",
    href: withLocale(locale, "/solutions"),
    label: "查看解決方案"
  },
  {
    title: "評估能力與服務",
    description: "當你想理解工程範圍：韌體、驗證、線束規劃與 OEM 交付方式。",
    href: withLocale(locale, "/capabilities"),
    label: "查看能力與服務"
  },
  {
    title: "快速獲得答案",
    description: "當你仍在判斷匹配度，或需要準備內部評審的詢價資訊包。",
    href: withLocale(locale, "/faq"),
    label: "閱讀常見問題"
  }
];
---

<MainLayout
  title="資源"
  description="宇睿電子的指南、清單與整合筆記，協助 OEM 團隊更好地定義控制板、替換遷移與觸控/HMI 需求。"
  structuredData={structuredData}
>
  <PageHero
    eyebrow="資源"
    title="面向工業顯示專案的指南、清單與整合筆記"
    intro="從模糊需求到可執行詢價：面板型號、介面約束、韌體期望、線束走線與量產交付。"
    highlight="目前是輕量的索引頁。隨著資源庫成長，可逐步替換占位圖為真實照片、圖表與應用場景素材。"
    actions={[
      { href: withLocale(locale, "/contact"), label: "溝通專案" },
      { href: withLocale(locale, "/products"), label: "瀏覽產品", variant: "secondary" }
    ]}
  >
    <Fragment slot="breadcrumbs">
      <Breadcrumbs
        items={[
          { label: "首頁", href: withLocale(locale, "/") },
          { label: "資源" }
        ]}
      />
    </Fragment>

    <VisualPlaceholder
      variant="grid"
      label="資源庫"
      subtitle="清單 · 遷移計畫 · 整合坑點"
      decorative={true}
    />

    <div class="info-stack">
      <div>
        <strong>最新</strong>
        <span>{posts.length} 篇文章 · 季度更新</span>
      </div>
      <div>
        <strong>適用對象</strong>
        <span>OEM 買方、工業工程師、整合與替換專案</span>
      </div>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="最新文章"
        title="更高品質的詢價，往往來自更清楚的共同語言"
        intro="這些內容適合快速內部分享：足夠對齊關鍵點，不需要完整規格書也能推進討論。"
      />

      <div class="card-grid">
        {latest.map((post) => (
          <article class="card card-link">
            <CardMedia label={post.data.title} />
            <p class="eyebrow">
              {post.data.publishDate.toLocaleDateString("zh-TW", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit"
              })}
            </p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="chip-cloud" aria-label="Tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )}
            <a class="text-link" href={withLocale(locale, `/resources/${post.slug}`)}>
              閱讀文章
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-contrast">
    <div class="container">
      <SectionHeading
        eyebrow="快速入口"
        title="從與你當前問題最匹配的角度進入"
        intro="並非所有團隊都從料號出發。下面的路徑協助更快自我篩選與定位下一步。"
      />

      <div class="card-grid">
        {quickLinks.map((item) => (
          <article class="card card-link">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a class="text-link" href={item.href}>{item.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CallToAction
    eyebrow="需要更快的路徑？"
    title="傳送面板型號與目標介面，宇睿可快速確認可行方案。"
    body="一份簡短的技術說明通常足以確認可行性、標出風險點，並給出最快的驗證計畫。"
    primaryLabel="聯絡宇睿"
    primaryHref={withLocale(locale, "/contact")}
    secondaryLabel="查看解決方案"
    secondaryHref={withLocale(locale, "/solutions")}
  />
</MainLayout>

