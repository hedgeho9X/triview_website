---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import CallToAction from "../../../components/CallToAction.astro";
import CardMedia from "../../../components/CardMedia.astro";
import PageHero from "../../../components/PageHero.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import VisualPlaceholder from "../../../components/VisualPlaceholder.astro";
import MainLayout from "../../../layouts/MainLayout.astro";
import { siteConfig } from "../../../data/site";
import { getLocaleFromUrl, withLocale } from "../../../i18n/routing";

const locale = getLocaleFromUrl(Astro.url.pathname);

const posts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const latest = posts.slice(0, 6);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: `${siteConfig.name} 资源`,
    url: `${siteConfig.siteUrl}/zh-Hans/resources`,
    description:
      "宇睿电子的指南、清单与集成笔记，面向 LCD 控制板与工业显示子系统项目。"
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: latest.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: post.data.title,
      url: `${siteConfig.siteUrl}/zh-Hans/resources/${post.slug}`
    }))
  }
];

const quickLinks = [
  {
    title: "快速确认接口覆盖",
    description:
      "当关键问题是可行性：面板侧接口（LVDS/eDP/V-by-One）、主机侧输入（HDMI/DP/DVI/VGA/USB-C）以及控制/OSD 范围。",
    href: withLocale(locale, "/interface-summary"),
    label: "打开接口概览"
  },
  {
    title: "浏览产品类别",
    description: "当你已明确硬件族群：控制板、scaler、触控或线束配套。",
    href: withLocale(locale, "/products"),
    label: "查看产品"
  },
  {
    title: "选择方案路径",
    description: "当关键问题是定制整合、生命周期迁移或稳定的 HMI 子系统交付。",
    href: withLocale(locale, "/solutions"),
    label: "查看解决方案"
  },
  {
    title: "评估能力与服务",
    description: "当你想理解工程范围：固件、验证、线束规划与 OEM 交付方式。",
    href: withLocale(locale, "/capabilities"),
    label: "查看能力与服务"
  },
  {
    title: "快速获得答案",
    description: "当你仍在判断匹配度，或需要准备内部评审的询价信息包。",
    href: withLocale(locale, "/faq"),
    label: "阅读常见问题"
  }
];
---

<MainLayout
  title="资源"
  description="宇睿电子的指南、清单与集成笔记，帮助 OEM 团队更好地定义控制板、替换迁移与触控/HMI 需求。"
  structuredData={structuredData}
>
  <PageHero
    eyebrow="资源"
    title="面向工业显示项目的指南、清单与集成笔记"
    intro="从模糊需求到可执行询价：面板型号、接口约束、固件期望、线束走线与量产交付。"
    highlight="目前是轻量的索引页。随着资源库增长，可逐步替换占位图为真实照片、图表与应用场景素材。"
    actions={[
      { href: withLocale(locale, "/contact"), label: "沟通项目" },
      { href: withLocale(locale, "/products"), label: "浏览产品", variant: "secondary" }
    ]}
  >
    <Fragment slot="breadcrumbs">
      <Breadcrumbs
        items={[
          { label: "首页", href: withLocale(locale, "/") },
          { label: "资源" }
        ]}
      />
    </Fragment>

    <VisualPlaceholder
      variant="grid"
      label="资源库"
      subtitle="清单 · 迁移计划 · 集成坑点"
      decorative={true}
    />

    <div class="info-stack">
      <div>
        <strong>最新</strong>
        <span>{posts.length} 篇文章 · 季度更新</span>
      </div>
      <div>
        <strong>适用对象</strong>
        <span>OEM 买方、工业工程师、集成与替换项目</span>
      </div>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="最新文章"
        title="更高质量的询价，往往来自更清晰的共同语言"
        intro="这些内容适合快速内部分享：足够对齐关键点，不需要完整规格书也能推进讨论。"
      />

      <div class="card-grid">
        {latest.map((post) => (
          <article class="card card-link">
            <CardMedia label={post.data.title} />
            <p class="eyebrow">
              {post.data.publishDate.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit"
              })}
            </p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="chip-cloud" aria-label="Tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )}
            <a class="text-link" href={withLocale(locale, `/resources/${post.slug}`)}>
              阅读文章
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-contrast">
    <div class="container">
      <SectionHeading
        eyebrow="快速入口"
        title="从与你当前问题最匹配的角度进入"
        intro="并非所有团队都从料号出发。下面的路径帮助更快自我筛选与定位下一步。"
      />

      <div class="card-grid">
        {quickLinks.map((item) => (
          <article class="card card-link">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a class="text-link" href={item.href}>{item.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CallToAction
    eyebrow="需要更快的路径？"
    title="发送面板型号与目标接口，宇睿可快速确认可行方案。"
    body="一份简短的技术说明通常足以确认可行性、标出风险点，并给出最快的验证计划。"
    primaryLabel="联系宇睿"
    primaryHref={withLocale(locale, "/contact")}
    secondaryLabel="查看解决方案"
    secondaryHref={withLocale(locale, "/solutions")}
  />
</MainLayout>

