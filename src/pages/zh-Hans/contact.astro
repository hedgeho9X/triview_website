---
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import InquiryForm from "../../components/InquiryForm.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import VisualPlaceholder from "../../components/VisualPlaceholder.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { siteConfig } from "../../data/site";
import { getLocaleFromUrl, withLocale } from "../../i18n/routing";

const locale = getLocaleFromUrl(Astro.url.pathname);

const contactAdvantages = [
  "支持新导入与替换项目的 RFQ/询价",
  "面向面板兼容与信号转换的工程评审",
  "定制线束与固件配套的试产协同",
  "当询价包含面板型号、主机信号与结构限制时，可显著加快评估速度"
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "联系宇睿电子",
  url: `${siteConfig.siteUrl}/zh-Hans/contact`,
  description:
    "联系宇睿电子，获取 LCD 控制板、AD 板、触控整合、线缆线束配套与 OEM 显示支持的询价与技术评审。"
};
---

<MainLayout
  title="联系我们"
  description="联系宇睿电子，获取 LCD 控制板、AD 板、触控模组与显示整合相关的询价与技术评审支持。"
  structuredData={structuredData}
>
  <PageHero
    eyebrow="联系我们"
    title="用足够清晰的信息开启沟通，让项目更快进入可执行路径"
    intro="宇睿最快的响应来自简洁、关键的工程输入：面板型号、主机接口、触控需求、预估量与目标时程。"
    highlight="高质量的首次询价能减少往返沟通，并更快锁定合适的控制板、配套硬件与 ODM/OEM 合作方式。"
    actions={[
      { href: `mailto:${siteConfig.contactEmail}`, label: "邮件联系" },
      { href: withLocale(locale, "/products"), label: "查看产品类别", variant: "secondary" }
    ]}
  >
    <Fragment slot="breadcrumbs">
      <Breadcrumbs
        items={[
          { label: "首页", href: withLocale(locale, "/") },
          { label: "联系我们" }
        ]}
      />
    </Fragment>

    <VisualPlaceholder
      variant="signal"
      label="询价信息包"
      subtitle="面板型号 · 主机接口 · 预估量 · 时程"
      decorative={true}
    />

    <div class="info-stack">
      <div>
        <strong>邮箱</strong>
        <span>{siteConfig.contactEmail}</span>
      </div>
      <div>
        <strong>电话</strong>
        <span>{siteConfig.contactPhone}</span>
      </div>
      <div>
        <strong>办公地点</strong>
        <span>{siteConfig.contactAddress}</span>
      </div>
    </div>
  </PageHero>

  <section class="section">
    <div class="container contact-grid">
      <div class="stack-grid">
        <article class="card">
          <p class="eyebrow">RFQ / 询价清单</p>
          <h2>建议在首次询价中包含</h2>
          <ul class="list-check">
            <li>LCD 面板型号、尺寸与目标分辨率</li>
            <li>主机信号类型（HDMI/DP/DVI/VGA/USB-C）与目标面板接口（LVDS/eDP/V-by-One）</li>
            <li>触控需求、前玻璃/结构概念与机内空间限制</li>
            <li>控制与体验需求，例如 RS232/RS485、OSD 默认值与品牌化</li>
            <li>工作环境（温度、占空比）与合规要求</li>
            <li>打样节奏、试产计划与年度预估量</li>
          </ul>
        </article>

        <article class="card">
          <p class="eyebrow">区域支持</p>
          <h2>面向全球 B2B 团队的项目支持</h2>
          <p>
            宇睿支持台湾、北美、欧洲与亚太地区的 OEM 团队。对于需要多方协作的项目，邮件优先通常是启动技术评审与报价的最有效方式。
          </p>
        </article>
      </div>

      <InquiryForm />
    </div>
  </section>

  <section class="section section-contrast">
    <div class="container split-grid split-grid-balanced">
      <div>
        <SectionHeading
          eyebrow="为什么建议提前沟通"
          title="早期技术沟通往往比后期救火更省时间"
          intro="在控制板与显示整合项目中，最有价值的对话往往发生在团队还没有锁死错误接口路径或线束方案之前。"
        />
        <div class="card card-emphasis">
          <ul class="list-check compact-list">
            {contactAdvantages.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <div>
        <SectionHeading
          eyebrow="联系方式汇总"
          title="直接联系信息"
          intro="如果你已准备好面板与接口信息，直接联系是最快的路径。"
        />

        <div class="card-grid">
          <article class="card">
            <h3>邮箱</h3>
            <p>
              <a class="text-link" href={`mailto:${siteConfig.contactEmail}`}>
                {siteConfig.contactEmail}
              </a>
            </p>
          </article>
          <article class="card">
            <h3>电话</h3>
            <p>
              <a class="text-link" href={`tel:${siteConfig.contactPhone.replaceAll("-", "")}`}>
                {siteConfig.contactPhone}
              </a>
            </p>
          </article>
          <article class="card">
            <h3>办公地点</h3>
            <p>{siteConfig.contactAddress}</p>
          </article>
          <article class="card">
            <h3>工作时间</h3>
            <p>{siteConfig.hours}</p>
          </article>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

