---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CallToAction from "../../components/CallToAction.astro";
import CardMedia from "../../components/CardMedia.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import VisualPlaceholder from "../../components/VisualPlaceholder.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { siteConfig } from "../../data/site";

const posts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const latest = posts.slice(0, 6);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    name: `${siteConfig.name} Resources`,
    url: `${siteConfig.siteUrl}/resources`,
    description:
      "Guides, checklists, and integration notes from TriView Electronics for LCD controller boards and industrial display subsystem work."
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: latest.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: post.data.title,
      url: `${siteConfig.siteUrl}/resources/${post.slug}`
    }))
  }
];

const quickLinks = [
  {
    title: "Confirm interface coverage",
    description:
      "Start here when the key question is feasibility: panel-side interfaces (LVDS/eDP/V-by-One), host-side inputs (HDMI/DP/DVI/VGA/USB-C), and control/OSD scope.",
    href: "/interface-summary",
    label: "Open interface summary"
  },
  {
    title: "Browse product categories",
    description:
      "Start here when you already know the hardware family: controller boards, scaler kits, touch, or harnesses.",
    href: "/products",
    label: "Explore products"
  },
  {
    title: "Choose a solution track",
    description:
      "Start here when the real question is custom integration, lifecycle migration, or building a stable HMI subsystem.",
    href: "/solutions",
    label: "Explore solutions"
  },
  {
    title: "Evaluate capabilities",
    description:
      "Start here when you want to understand engineering scope: firmware, validation, cable planning, and OEM handoff.",
    href: "/capabilities",
    label: "View capabilities"
  },
  {
    title: "Get answers fast",
    description:
      "Start here when you're still checking fit or preparing an RFQ packet for an internal stakeholder review.",
    href: "/faq",
    label: "Read FAQ"
  }
];
---

<MainLayout
  title="Resources"
  description="Guides, checklists, and integration notes from TriView Electronics to help OEM teams scope controller boards, legacy replacement, and touch/HMI stability."
  path="/resources"
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Resources"
    title="Guides, checklists, and integration notes for industrial display programs"
    intro="Use these resources to move from vague requirements to a clean inquiry: panel model, interface constraints, firmware expectations, harness routing, and production handoff."
    highlight="This is a lightweight blog-style index today. Replace the placeholder visuals with real photos, diagrams, and application imagery as the library grows."
    actions={[
      { href: "/contact", label: "Discuss a project" },
      { href: "/products", label: "Browse products", variant: "secondary" }
    ]}
  >
    <Fragment slot="breadcrumbs">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Resources" }]} />
    </Fragment>

    <VisualPlaceholder
      variant="grid"
      label="Resource Library"
      subtitle="Checklists · migration plans · integration pitfalls"
      decorative={true}
    />

    <div class="info-stack">
      <div>
        <strong>Latest</strong>
        <span>{posts.length} articles · updated quarterly</span>
      </div>
      <div>
        <strong>Best for</strong>
        <span>OEM buyers, industrial engineers, integration and replacement programs</span>
      </div>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Latest Articles"
        title="Short, practical notes that improve inquiry quality"
        intro="These guides are designed for fast internal sharing: enough detail to align stakeholders, without requiring a full spec review."
      />

      <div class="card-grid">
        {latest.map((post) => (
          <article class="card card-link">
            <CardMedia label={post.data.title} />
            <p class="eyebrow">
              {post.data.publishDate.toLocaleDateString("en", {
                year: "numeric",
                month: "short",
                day: "2-digit"
              })}
            </p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="chip-cloud" aria-label="Tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )}
            <a class="text-link" href={`/resources/${post.slug}`}>
              Read article
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-contrast">
    <div class="container">
      <SectionHeading
        eyebrow="Quick Navigation"
        title="Enter from the angle that matches your real problem"
        intro="Not every buyer starts with a part number. These routes help teams self-qualify quickly."
      />

      <div class="card-grid">
        {quickLinks.map((item) => (
          <article class="card card-link">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a class="text-link" href={item.href}>{item.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CallToAction
    eyebrow="Need a shortcut?"
    title="Send the panel model and target interface. TriView can scope the controller path quickly."
    body="A short technical note is often enough to confirm feasibility, highlight risk points, and propose the fastest evaluation plan."
    primaryLabel="Contact TriView"
    primaryHref="/contact"
    secondaryLabel="Explore solutions"
    secondaryHref="/solutions"
  />
</MainLayout>

