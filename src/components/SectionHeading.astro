---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: "left" | "center";
}

const { eyebrow, title, intro, align = "left" } = Astro.props;
---

<div class={align === "center" ? "section-heading section-heading-center" : "section-heading"}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {intro && <p class="section-intro">{intro}</p>}
</div>
