---
import crypto from "node:crypto";

interface Props {
  label: string;
  decorative?: boolean;
}

const { label, decorative = true } = Astro.props;
const uid = crypto.createHash("sha1").update(label).digest("hex").slice(0, 10);
const titleId = `cm-title-${uid}`;
---

<div class="card-media">
  <svg
    viewBox="0 0 640 360"
    width="640"
    height="360"
    role={decorative ? "presentation" : "img"}
    aria-hidden={decorative ? "true" : undefined}
    aria-labelledby={!decorative ? titleId : undefined}
    xmlns="http://www.w3.org/2000/svg"
  >
    {!decorative && <title id={titleId}>{label}</title>}

    <defs>
      <linearGradient id={`cm-bg-${uid}`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="rgba(194,111,74,0.22)" />
        <stop offset="0.48" stop-color="rgba(255,255,255,0.06)" />
        <stop offset="1" stop-color="rgba(46,139,139,0.16)" />
      </linearGradient>
      <linearGradient id={`cm-line-${uid}`} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="rgba(255,255,255,0)" />
        <stop offset="0.3" stop-color="rgba(255,255,255,0.55)" />
        <stop offset="0.7" stop-color="rgba(255,255,255,0.32)" />
        <stop offset="1" stop-color="rgba(255,255,255,0)" />
      </linearGradient>
    </defs>

    <rect x="0" y="0" width="640" height="360" rx="26" fill="#0b1320" />
    <rect x="0" y="0" width="640" height="360" rx="26" fill={`url(#cm-bg-${uid})`} opacity="0.95" />

    <g opacity="0.9">
      <path
        d="M 48 98 H 592"
        stroke={`url(#cm-line-${uid})`}
        stroke-width="2"
        stroke-linecap="round"
      />
      <path
        d="M 48 180 H 592"
        stroke={`url(#cm-line-${uid})`}
        stroke-width="2"
        stroke-linecap="round"
      />
      <path
        d="M 48 262 H 592"
        stroke={`url(#cm-line-${uid})`}
        stroke-width="2"
        stroke-linecap="round"
      />
    </g>

    <g fill="rgba(255,255,255,0.7)" opacity="0.9">
      {[
        [120, 98],
        [330, 98],
        [510, 98],
        [160, 180],
        [400, 180],
        [540, 262]
      ].map(([x, y]) => (
        <circle cx={x} cy={y} r="4.5" />
      ))}
    </g>

    <g font-family="IBM Plex Mono, ui-monospace, monospace">
      <text x="40" y="320" fill="rgba(255,255,255,0.8)" font-size="13" letter-spacing="0.12em">
        {label.toUpperCase()}
      </text>
      <text x="40" y="342" fill="rgba(255,255,255,0.55)" font-size="12">
        PLACEHOLDER VISUAL
      </text>
    </g>
  </svg>
</div>
