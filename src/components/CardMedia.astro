---
import crypto from "node:crypto";

interface Props {
  label: string;
  decorative?: boolean;
}

const { label, decorative = true } = Astro.props;
const uid = crypto.createHash("sha1").update(label).digest("hex").slice(0, 10);
const titleId = `cm-title-${uid}`;
---

<div class="card-media">
  <svg
    viewBox="0 0 640 360"
    width="640"
    height="360"
    role={decorative ? "presentation" : "img"}
    aria-hidden={decorative ? "true" : undefined}
    aria-labelledby={!decorative ? titleId : undefined}
    xmlns="http://www.w3.org/2000/svg"
  >
    {!decorative && <title id={titleId}>{label}</title>}

    <defs>
      <linearGradient id={`cm-bg-${uid}`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="rgba(2, 132, 199, 0.2)" /> <!-- var(--accent) #0284c7 -->
        <stop offset="0.5" stop-color="rgba(15, 23, 42, 0.4)" /> <!-- var(--ink) #0f172a -->
        <stop offset="1" stop-color="rgba(234, 88, 12, 0.15)" /> <!-- var(--accent-2) #ea580c -->
      </linearGradient>
      <linearGradient id={`cm-line-${uid}`} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="rgba(255,255,255,0)" />
        <stop offset="0.3" stop-color="rgba(255,255,255,0.4)" />
        <stop offset="0.7" stop-color="rgba(255,255,255,0.2)" />
        <stop offset="1" stop-color="rgba(255,255,255,0)" />
      </linearGradient>
      <pattern id={`cm-grid-${uid}`} width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
      </pattern>
    </defs>

    <rect x="0" y="0" width="640" height="360" rx="16" fill="#0f172a" />
    <rect x="0" y="0" width="640" height="360" rx="16" fill={`url(#cm-bg-${uid})`} />
    <rect x="0" y="0" width="640" height="360" rx="16" fill={`url(#cm-grid-${uid})`} />

    <g opacity="0.8">
      <path
        d="M 40 100 H 600"
        stroke={`url(#cm-line-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
      />
      <path
        d="M 40 180 H 600"
        stroke={`url(#cm-line-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
      />
      <path
        d="M 40 260 H 600"
        stroke={`url(#cm-line-${uid})`}
        stroke-width="1.5"
        stroke-linecap="round"
      />
    </g>

    <g fill="#38bdf8" opacity="0.9"> <!-- Tech Blue Accent -->
      {[
        [140, 100],
        [360, 100],
        [480, 100],
        [200, 180],
        [420, 180],
        [520, 260]
      ].map(([x, y]) => (
        <circle cx={x} cy={y} r="4" />
      ))}
      <circle cx="200" cy="180" r="8" fill="none" stroke="#38bdf8" stroke-width="2" opacity="0.5" />
      <circle cx="480" cy="100" r="8" fill="none" stroke="#38bdf8" stroke-width="2" opacity="0.5" />
    </g>

    <g font-family="Inter, ui-monospace, monospace">
      <text x="32" y="315" fill="rgba(255,255,255,0.9)" font-size="14" font-weight="600" letter-spacing="0.05em">
        {label.toUpperCase()}
      </text>
      <text x="32" y="338" fill="rgba(255,255,255,0.5)" font-size="11" letter-spacing="0.1em">
        SYSTEM COMPONENT
      </text>
    </g>
  </svg>
</div>
